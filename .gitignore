# =====================
# Operating System
# =====================
# macOS
.DS_Store
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# =====================
# Node & Package Managers
# =====================
node_modules/
yarn-error.log
npm-debug.log*
.pnpm-debug.log*

# =====================
# Expo & React Native
# =====================
.expo/                   # local Expo state
.expo-shared/            # auto-generated by expo-cli
web-build/               # Expo web output
android/app/build/       # Android build artifacts
ios/build/               # iOS build artifacts
*.keystore               # Android keystores (if you’re generating builds locally)
*.p8                     # Expo Push Key
*.jks
*.p12
*.key
*.mobileprovision

# auto-generated env types by Expo CLI

# =====================
# Backend
# =====================
dist/                    # compiled output
coverage/                # test coverage reports
.env                     # environment variables (never commit secrets!)
.env.*                   # if you use .env.local, .env.production etc.

# =====================
# Logs
# =====================
logs/
*.log

# =====================
# SQL Files
# =====================
# Ignore SQL by default, but keep tracked migrations/seeds
*.sql
!backend/supabase/migrations/**/*.sql
!backend/supabase/seeds/**/*.sql
!supabase/migrations/**/*.sql
!supabase/seeds/**/*.sql
SQL/
SQLScripts/
data-dumps/
database-backups/

# =====================
# IDEs & Editors
# =====================
# VS Code
.vscode/
.vscode/*

# Cursor IDE
.cursor/
.cursor/*

# IntelliJ / WebStorm
.idea/
*.iml

# =====================
# Miscellaneous
# =====================
*.orig                  # patch rejections.env*
.env*

# =====================
# Next.js & Build Artifacts
# =====================
.next/
.next/*
*/.next/
*/.next/*
build/
dist/
out/

# =====================
# Cache & Temporary Files
# =====================
.cache/
*/.cache/
*/cache/
*.tsbuildinfo
.turbo/
*/.turbo/

# =====================
# Large Build Files
# =====================
*.pack
*.idx
*.rev

# =====================
# SQL and Database Files
# =====================
# Exclude large SQL files but keep tracked migrations/seeds
*.dump
*.gz
*.tar
*.zip
*.csv
**/SQL/
