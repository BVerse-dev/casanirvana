SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
PORT=3000
# Comma-separated origins allowed by CORS.
# Supports exact origins and wildcard rules like https://*.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://*.vercel.app
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,application/pdf
UPLOAD_BUCKET=uploads
ADMIN_INVITE_REDIRECT_URL=
ONBOARDING_REQUEST_API_KEY=
OBSERVABILITY_RATE_LIMIT_WINDOW_MS=900000
OBSERVABILITY_RATE_LIMIT_MAX=60
# Backend-only automation secrets (generate unique values per environment)
PAYMENT_CHARGE_CRON_API_KEY=
PAYOUT_AUTOMATION_API_KEY=
EXPRESSPAY_MODE=test
EXPRESSPAY_MERCHANT_ID=
EXPRESSPAY_API_KEY=
EXPRESSPAY_CALLBACK_BASE_URL=
EXPRESSPAY_SUBMIT_URL=
EXPRESSPAY_QUERY_URL=
EXPRESSPAY_CHECKOUT_URL=
EXPRESSPAY_BILLPAY_MODE=test
EXPRESSPAY_BILLPAY_URL=
EXPRESSPAY_BILLPAY_USERNAME=
EXPRESSPAY_BILLPAY_AUTH_TOKEN=
LOG_LEVEL=info
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
