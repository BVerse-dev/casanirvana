{
  "name": "casa-nirvana-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec tsx src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc",
    "lint": "eslint . --ext .ts",
    "supabase:start": "supabase start",
    "supabase:push": "supabase db push",
    "supabase:gen:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF --schema public --out-file src/lib/database.types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.33.1",
    "@types/multer": "^1.4.13",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "multer": "^2.0.1",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "eslint": "^9.9.1",
    "globals": "^15.9.0",
    "nodemon": "^3.1.10",
    "supabase": "^1.58.1",
    "tsx": "^4.19.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0"
  }
}
