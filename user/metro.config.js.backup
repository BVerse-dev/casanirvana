const { getDefaultConfig } = require('expo/metro-config');
const path = require('path');

const config = getDefaultConfig(__dirname);

// Workaround for Metro config issues with newer versions
// Remove problematic plugins that might cause module resolution issues
if (config.serializer && config.serializer.customSerializer) {
  config.serializer.customSerializer = undefined;
}

// Configure for SVG support
config.resolver.assetExts = config.resolver.assetExts.filter(ext => ext !== 'svg');
config.resolver.sourceExts = [...config.resolver.sourceExts, 'svg'];

// Force using a single version of react-native-safe-area-context
config.resolver.extraNodeModules = {
  'react-native-safe-area-context': path.resolve(__dirname, 'node_modules/react-native-safe-area-context'),
};

// Configure the transformer for SVG
config.transformer = {
  ...config.transformer,
  babelTransformerPath: require.resolve('react-native-svg-transformer')
};

module.exports = config;
