  {
    key: "3",
    image: require("../assets/images/pic1.png"),
    title: "Electricity",
    dateTime: "22 Aug, 03:30 pm",
    other: "Power fluctuates sometime",
    resolved: true,
    name: "George Haydon",
  },
];

const communityList = [
  {
    key: "1",
    image: require("../assets/images/pic1.png"),
    title: "Parking",
    dateTime: "22 Aug, 03:30 pm",
    other: "Water leakage in parking area",
    name: "Raghuveer Patel",
  },
  {
    key: "2",
    image: require("../assets/images/member1.png"),
    title: "Plumbing",
    dateTime: "22 Aug, 03:30 pm",
    other: "Valve is not working",
    name: "Natasha jain",
  },
  {
    key: "3",
    image: require("../assets/images/visitor2.png"),
    title: "Electricity",
    dateTime: "22 Aug, 03:30 pm",
    other: "Power fluctuates sometime",
    resolved: true,
    name: "George Haydon",
  },
  {
    key: "4",
    image: require("../assets/images/pic1.png"),
    title: "Parking",
    dateTime: "22 Aug, 03:30 pm",
    other: "Water leakage in parking area",
    name: "Mihir sharma",
  },
];

const ComplaintsScreen = ({ navigation }) => {
  const [selectedTab, setSelectedTab] = useState('personal');
  const [status, setStatus] = useState('');
  const [search, setSearch] = useState('');

  // Filtered data based on tab, status, and search
  const data = (selectedTab === 'personal' ? personalList : communityList)
    .filter(item =>
      (!status || (status === 'resolved' ? item.resolved : !item.resolved)) &&
      (search === '' || item.title.toLowerCase().includes(search.toLowerCase()) || item.other.toLowerCase().includes(search.toLowerCase()))
    );

  // Use the exact renderItem and styles from HelpDeskPersonalTab/HelpDeskCommunityTab
  const isRtl = false; // Set from i18n if needed
  function tr(key) {
    if (selectedTab === 'personal') {
      if (key === 'resolvedBy') return 'Resolved by';
      if (key === 'raisedBy') return 'Raised by';
      if (key === 'resolved') return 'Resolved';
      if (key === 'pending') return 'Pending';
    } else {
      if (key === 'resolvedBy') return 'Resolved by';
      if (key === 'raisedBy') return 'Raised by';
      if (key === 'resolved') return 'Resolved';
      if (key === 'pending') return 'Pending';
    }
    return key;
  }


  // HelpDesk-style renderComplaint (copied from above, only one definition)
  const renderComplaint = ({ item }) => (
    <TouchableOpacity
      onPress={() => navigation && navigation.navigate('complaintDetailScreen', {
        headerTitle: selectedTab === 'personal' ? 'Personal' : 'Community',
        image: item.image,
        title: item.title,
        dateTime: item.dateTime,
        other: item.other,
        name: item.name,
        resolved: item.resolved,
      })}
      style={{
        flexDirection: isRtl ? 'row-reverse' : 'row',
        ...styles.mainTouchOpacity,
      }}
    >
      <View
        style={{
          flex: 1,
          flexDirection: isRtl ? 'row-reverse' : 'row',
          alignItems: 'center',
        }}
      >
        <Image
          source={item.image}
          style={{
            width: 87,
            height: 87,
            borderRadius: 5,
            marginTop: Default.fixPadding * 1.5,
          }}
        />
        <View
          style={{
            flex: 1,
            alignItems: isRtl ? 'flex-end' : 'flex-start',
            marginLeft: isRtl ? 0 : Default.fixPadding,
            marginRight: isRtl ? Default.fixPadding : 0,
          }}
        >
          <Text
            numberOfLines={1}
            style={{
              ...Fonts.SemiBold16black,
              overflow: 'hidden',
              textAlign: isRtl ? 'right' : 'left',
              paddingTop: Default.fixPadding,
              marginRight: isRtl ? 0 : Default.fixPadding * 10,
              marginLeft: isRtl ? Default.fixPadding * 10 : 0,
            }}
          >
            {item.title}
          </Text>
          <View
            style={{
              alignItems: isRtl ? 'flex-end' : 'flex-start',
              marginRight: isRtl ? 0 : Default.fixPadding,
              marginLeft: isRtl ? Default.fixPadding : 0,
            }}
          >
            <Text numberOfLines={1} style={{ ...Fonts.Medium14grey, overflow: 'hidden' }}>{item.dateTime}</Text>
            <Text numberOfLines={1} style={{ ...Fonts.Medium14grey, overflow: 'hidden', marginVertical: Default.fixPadding * 0.3 }}>{item.other}</Text>
            <Text numberOfLines={1} style={{ ...Fonts.Medium14grey, overflow: 'hidden' }}>
              {item.resolved ? tr('resolvedBy') : tr('raisedBy')}
              <Text style={{ ...Fonts.Medium14black }}>{` : ${item.name}`}</Text>
            </Text>
          </View>
        </View>
      </View>
      <View
        style={{
          position: 'absolute',
          right: isRtl ? null : 0,
          left: isRtl ? 0 : null,
          justifyContent: 'center',
          alignItems: 'center',
          width: 90,
          paddingVertical: Default.fixPadding * 0.3,
          backgroundColor: item.resolved ? Colors.green : Colors.red,
          borderTopRightRadius: isRtl ? 0 : 10,
          borderTopLeftRadius: isRtl ? 10 : 0,
        }}
      >
        <Text numberOfLines={1} style={{ ...Fonts.SemiBold16white, overflow: 'hidden', paddingHorizontal: Default.fixPadding * 0.5 }}>
          {item.resolved ? tr('resolved') : tr('pending')}
        </Text>
      </View>
    </TouchableOpacity>
  );

  return (
    <View style={{ flex: 1, backgroundColor: Colors.white }}>
      {/* Status Bar and Red Bar */}
      <MyStatusBar />
      <View style={styles.redBar} />
      {/* Header Row: Arrow & Title (on white, below red bar) */}
      <View style={styles.headerRow}>
        <TouchableOpacity
          style={styles.headerBackBtn}
          onPress={() => {
            if (navigation && navigation.canGoBack && navigation.canGoBack()) {
              navigation.goBack();
            } else if (navigation && navigation.navigate) {
              navigation.navigate('helpDeskScreen');
            }
          }}>
          <Ionicons name="arrow-back-outline" size={25} color={Colors.black} />
        </TouchableOpacity>
        <Text style={styles.headerTitleText}>Complaints</Text>
      </View>

      {/* Tab Row: Personal / Community */}
      <View style={styles.filterRowWrapper}>
        <View style={styles.filterRow}>
          <TouchableOpacity
            onPress={() => setSelectedTab('personal')}
            style={[
              styles.tabBtn,
              selectedTab === 'personal' && styles.activeTabBtn,
              // Make both tabs take equal width
              { flex: 1 },
            ]}
          >
            <Text style={selectedTab === 'personal' ? Fonts.SemiBold16white : Fonts.SemiBold16grey} numberOfLines={1}>
              Personal
            </Text>
          </TouchableOpacity>
          <TouchableOpacity
            onPress={() => setSelectedTab('community')}
            style={[
              styles.tabBtn,
              selectedTab === 'community' && styles.activeTabBtn,
              { flex: 1 },
            ]}
          >
            <Text style={selectedTab === 'community' ? Fonts.SemiBold16white : Fonts.SemiBold16grey} numberOfLines={1}>
              Community
            </Text>
          </TouchableOpacity>
        </View>
      </View>

      {/* Search & Add */}
      <View style={styles.searchRow}>
        <TextInput
          style={styles.searchInput}
          placeholder="Search complaints..."
          value={search}
          onChangeText={setSearch}
          placeholderTextColor={Colors.grey}
        />
        <TouchableOpacity style={styles.addBtn} onPress={() => navigation && navigation.navigate('addComplaintScreen')}>
          <Text style={{ color: Colors.white, fontWeight: 'bold', fontSize: 22 }}>+</Text>
        </TouchableOpacity>
      </View>

      {/* Filter Row: Status */}
      <View style={styles.filterRowWrapper}>
        <View style={styles.filterRow}>
          <TouchableOpacity onPress={() => setStatus('')} style={[styles.filterBtn, !status && styles.activeFilterBtn]}>
            <Text style={!status ? Fonts.Medium14white : Fonts.Medium14black}>All</Text>
          </TouchableOpacity>
          <TouchableOpacity onPress={() => setStatus('pending')} style={[styles.filterBtn, status === 'pending' && styles.activeFilterBtn]}>
            <Text style={status === 'pending' ? Fonts.Medium14white : Fonts.Medium14black}>Pending</Text>
          </TouchableOpacity>
          <TouchableOpacity onPress={() => setStatus('resolved')} style={[styles.filterBtn, status === 'resolved' && styles.activeFilterBtn]}>
            <Text style={status === 'resolved' ? Fonts.Medium14white : Fonts.Medium14black}>Resolved</Text>
          </TouchableOpacity>
        </View>
      </View>

      {/* List */}
      <FlatList
        data={data}
        keyExtractor={item => item.key}
        renderItem={renderComplaint}
        contentContainerStyle={styles.listContent}
        showsVerticalScrollIndicator={false}
        ListEmptyComponent={
          <View style={styles.emptyState}>
            <Text style={{ textAlign: 'center', marginTop: 8, color: Colors.grey }}>
              No complaints found.
            </Text>
          </View>
        }
      />
    </View>
  );
};

