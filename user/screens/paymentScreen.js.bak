import React, { useState } from "react";
import {
  StyleSheet,
  Text,
  View,
  TouchableOpacity,
  Image,
  FlatList,
} from "react-native";
import MyStatusBar from "../components/myStatusBar";
import { Colors, Fonts, Default } from "../constants/styles";
import { useTranslation } from "react-i18next";
import { ms } from "react-native-size-matters/extend";
import MaterialCommunityIcons from "react-native-vector-icons/MaterialCommunityIcons";
import PaymentModal from "../components/paymentModal.js"; // Ensure the correct file name

const PaymentScreen = ({ navigation }) => {
  const { t, i18n } = useTranslation();

  const isRtl = i18n.dir() == "rtl";

  function tr(key) {
    return t(`paymentScreen:${key}`);
  }

  const [openPaymentModal, setOpenPaymentModal] = useState(false);
  const [selectedPayment, setSelectedPayment] = useState(null);

  const paymentList = [
    {
      key: "1",
      title: tr("hoa"),
      description: tr("hoaDescription"),
      image: require("../assets/images/service1.png"),
    },
    {
      key: "2",
      title: tr("electricity"),
      description: tr("electricityDescription"),
      image: require("../assets/images/service2.png"),
    },
    {
      key: "3",
      title: tr("water"),
      description: tr("waterDescription"),
      image: require("../assets/images/service3.png"),
    },
    {
      key: "4",
      title: tr("maintenance"),
      description: tr("maintenanceDescription"),
      image: require("../assets/images/service.png"),
    },
  ];

  const renderItem = ({ item, index }) => {
    return (
      <TouchableOpacity
        onPress={() => {
          setSelectedPayment(item); // Set the selected payment
          setOpenPaymentModal(true); // Open the PaymentModal
        }}
        style={{
          marginRight: index % 2 === 0 ? 0 : Default.fixPadding * 2,
          ...styles.paymentTouchableOpacity,
        }}
      >
        <Image
          source={item.image}
          style={{ width: 35, height: 35, resizeMode: "contain" }}
        />
        <Text
          numberOfLines={2}
          style={{
            ...Fonts.Medium15primary,
            overflow: "hidden",
            marginTop: Default.fixPadding,
            textAlign: "center",
          }}
        >
          {item.title}
        </Text>
        <Text
          style={{
            ...Fonts.Medium12grey,
            overflow: "hidden",
            marginTop: Default.fixPadding * 0.2,
            textAlign: "center",
          }}
        >
          {item.description}
        </Text>
      </TouchableOpacity>
    );
  };

  return (
    <View style={{ flex: 1, backgroundColor: Colors.regularGrey }}>
      <MyStatusBar />
      <View
        style={{
          flexDirection: "row",
          alignItems: "center",
          paddingHorizontal: Default.fixPadding * 2,
          paddingVertical: Default.fixPadding * 1.2,
          backgroundColor: Colors.white,
        }}
      >
        <TouchableOpacity onPress={() => navigation.goBack()}>
          <MaterialCommunityIcons
            name="arrow-left"
            size={24}
            color={Colors.black}
          />
        </TouchableOpacity>
        <Text
          style={{
            ...Fonts.SemiBold22black,
            textAlign: isRtl ? "right" : "left",
            marginLeft: Default.fixPadding * 2,
          }}
        >
          {tr("payment")}
        </Text>
      </View>

      <FlatList
        numColumns={2}
        data={paymentList}
        renderItem={renderItem}
        keyExtractor={(item) => item.key}
        showsVerticalScrollIndicator={false}
        contentContainerStyle={{ paddingBottom: Default.fixPadding * 2 }}
        ListHeaderComponent={() => (
          <View
            style={{
              paddingTop: Default.fixPadding * 0.8,
              paddingBottom: Default.fixPadding * 2,
              paddingHorizontal: Default.fixPadding * 2,
              marginBottom: Default.fixPadding * 2,
              backgroundColor: Colors.white,
            }}
          >
            <Text
              style={{
                ...Fonts.SemiBold16black,
                textAlign: isRtl ? "right" : "left",
              }}
            >
              {tr("yourPayments")}
            </Text>

            <View
              style={{
                overflow: "hidden",
                flexDirection: isRtl ? "row-reverse" : "row",
                marginTop: Default.fixPadding,
                marginBottom: Default.fixPadding * 2,
                borderRadius: 10,
                borderWidth: 1,
                borderColor: Colors.lightLinkWater,
              }}
            >
              <View style={{ flex: 0.2, backgroundColor: Colors.primary }} />
              <View
                style={{
                  flex: 9.8,
                  flexDirection: isRtl ? "row-reverse" : "row",
                  justifyContent: "center",
                  backgroundColor: Colors.linkWater,
                }}
              >
                <View
                  style={{
                    flex: 7,
                    alignItems: isRtl ? "flex-end" : "flex-start",
                    margin: Default.fixPadding * 1.3,
                  }}
                >
                  <Text
                    numberOfLines={2}
                    style={{ ...Fonts.SemiBold16primary, overflow: "hidden" }}
                  >
                    {tr("hoa")}
                  </Text>
                  <Text
                    style={{
                      ...Fonts.Medium14grey,
                      overflow: "hidden",
                      marginVertical: Default.fixPadding * 0.6,
                    }}
                  >
                    {tr("hoaDescription")}
                  </Text>

                  <View
                    style={{
                      flexDirection: isRtl ? "row-reverse" : "row",
                      alignItems: "center",
                    }}
                  >
                    <MaterialCommunityIcons
                      name="calendar-range-outline"
                      size={16}
                      color={Colors.grey}
                    />
                    <Text
                      style={{
                        ...Fonts.Medium12black,
                        marginHorizontal: Default.fixPadding * 0.5,
                      }}
                    >
                      {`9 Jun 2025 | 14:30`}
                    </Text>
                  </View>
                </View>

                <View
                  style={{
                    flex: 2.8,
                    justifyContent: "flex-end",
                    alignItems: isRtl ? "flex-start" : "flex-end",
                    paddingHorizontal: Default.fixPadding * 0.6,
                  }}
                >
                  <Image
                    source={require("../assets/images/service.png")}
                    style={{
                      resizeMode: "contain",
                      width: ms(80),
                      height: ms(80),
                    }}
                  />
                </View>
              </View>
            </View>

            <Text
              style={{
                ...Fonts.SemiBold16black,
                textAlign: isRtl ? "right" : "left",
              }}
            >
              {tr("nearbyProviders")}
            </Text>
          </View>
        )}
      />

      <View style={styles.buttonWrapper}>
        <TouchableOpacity
          style={styles.button}
          onPress={() => navigation.navigate('paymentHistoryScreen')} // Navigate to paymentHistoryScreen
        >
          <Text style={styles.buttonText}>View Payment History</Text>
        </TouchableOpacity>
        <TouchableOpacity style={styles.button}>
          <Text style={styles.buttonText}>View Statements</Text>
        </TouchableOpacity>
      </View>

      <PaymentModal
        visible={openPaymentModal}
        closePaymentModal={() => setOpenPaymentModal(false)}
        image={selectedPayment?.image} // Pass the selected payment image
        title={selectedPayment?.title} // Pass the selected payment title
      />
    </View>
  );
};

export default PaymentScreen;

const styles = StyleSheet.create({
  paymentTouchableOpacity: {
    flex: 1,
    justifyContent: "center",
    alignItems: "center",
    paddingVertical: Default.fixPadding * 3,
    paddingHorizontal: Default.fixPadding,
    marginLeft: Default.fixPadding * 2,
    marginBottom: Default.fixPadding * 2,
    borderRadius: 20,
    backgroundColor: Colors.white,
    ...Default.shadow,
  },
  buttonWrapper: {
    paddingHorizontal: Default.fixPadding * 5,
    paddingVertical: Default.fixPadding * 2,
    backgroundColor: Colors.white,
    borderRadius: 20,
  },
  button: {
    alignItems: "center",
    justifyContent: "center",
    paddingVertical: Default.fixPadding * 1.5,
    marginVertical: Default.fixPadding,
    borderRadius: 15,
    backgroundColor: Colors.primary,
  },
  buttonText: {
    ...Fonts.SemiBold16white,
  },
});