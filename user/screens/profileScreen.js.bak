        >
          {tr("profile")}
        </Text>
        <TouchableOpacity onPress={() => navigation.push("settingScreen")}>
          <AntDesign name={"setting"} size={24} color={Colors.black} />
        </TouchableOpacity>
      </View>
      <ScrollView showsVerticalScrollIndicator={false}>
        <View
