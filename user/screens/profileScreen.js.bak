                  justifyContent: "center",
                  alignItems: "center",
                  width: 55,
                  height: 55,
                  borderRadius: 28,
                  backgroundColor: Colors.white,
                  ...Default.shadow,
                }}
              >
                <Image
                  source={require("../assets/images/pic1.png")}
                  style={{
                    width: 52,
                    height: 52,
                    borderRadius: 26,
                  }}
                />
              </View>
            </View>
            <View
              style={{
                flex: 6.3,
                alignItems: isRtl ? "flex-end" : "flex-start",
                marginHorizontal: Default.fixPadding,
              }}
            >
