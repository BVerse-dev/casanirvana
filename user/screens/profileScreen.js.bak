import React, { useState } from "react";
import {
  StyleSheet,
  Text,
  View,
  TouchableOpacity,
  Image,
  FlatList,
  ScrollView,
  Share,
} from "react-native";
import MyStatusBar from "../components/myStatusBar";
import { Colors, Fonts, Default } from "../constants/styles";
import { useTranslation } from "react-i18next";
import { ms } from "react-native-size-matters/extend";
import AntDesign from "react-native-vector-icons/AntDesign";
import DashedLine from "react-native-dashed-line";
import MaterialCommunityIcons from "react-native-vector-icons/MaterialCommunityIcons";
import Octicons from "react-native-vector-icons/Octicons";
import Entypo from "react-native-vector-icons/Entypo";
import AddFamilyMemberModal from "../components/addFamilyMemberModal";
import MyVehiclesModal from "../components/myVehiclesModal";
import GatePassModal from "../components/gatePassModal";

const ProfileScreen = ({ navigation }) => {
  const { t, i18n } = useTranslation();

  const isRtl = i18n.dir() == "rtl";

  function tr(key) {
    return t(`profileScreen:${key}`);
  }

  const shareMessage = () => {
    Share.share({
      message: "SEVENGEN",
    });
  };  const myFamilyList = [
    {
      key: "1",
      image: require("../assets/images/img16.png"),
      name: "Samuel Asante",
      other: "Father",
    },
    {
      key: "2",
      image: require("../assets/images/img20.png"),
      name: "Grace Williams",
      other: "Mother",
    },
    {
      key: "3",
      image: require("../assets/images/img21.png"),
      name: "Akosua Thompson",
      other: "Wife",
    },
    {
      key: "4",
      image: require("../assets/images/visitor4.png"),
      name: "Daniel Osei",
      other: "Son",
    },
    {
      key: "5",
      image: require("../assets/images/img22.png"),
      name: "Abena Johnson",
      other: "Daughter",
    },
  ];  const dailyHelpList = [
    {
      key: "1",
      image: require("../assets/images/img11.png"),
      name: "Mary Adjei",
      other: "House Cleaning",
    },
    {
      key: "2",
      image: require("../assets/images/img5.png"),
      name: "Comfort Boateng",
      other: "Laundry Service",
    },
    {
      key: "3",
      image: require("../assets/images/img25.png"),
      name: "Joseph Mensah",
      other: "Milk Delivery",
    },
  ];
  const myVehiclesList = [
    {
      key: "1",
      image: require("../assets/images/img23.png"),
      name: "CN-2024-A420",
      other: "Honda Civic (Black)",
    },
    {
      key: "2",
      image: require("../assets/images/img24.png"),
      name: "CN-2023-B110",
      other: "Toyota Camry (White)",
    },
  ];
  const frequentEntriesList = [
    {
      key: "1",
      image: require("../assets/images/member13.png"),
      name: "Emmanuel Darko",
      other: "Friend",
    },
    {
      key: "2",
      image: require("../assets/images/img15.png"),
      name: "Rebecca Anderson",
      other: "Friends",
    },
  ];

  const [selectedName, setSelectedName] = useState();

  const renderItem = ({ item }) => {
    return (
      <View
        style={{
          flex: 1,
          padding: Default.fixPadding,
          marginHorizontal: Default.fixPadding * 0.75,
          marginTop: Default.fixPadding * 1.5,
          marginBottom: Default.fixPadding * 2.5,
          maxWidth: ms(130),
          borderRadius: 10,
          backgroundColor: Colors.white,
          ...Default.shadow,
        }}
      >
        <View
          style={{
            flexDirection: isRtl ? "row-reverse" : "row",
            justifyContent: "flex-start",
          }}
        >
          <Image
