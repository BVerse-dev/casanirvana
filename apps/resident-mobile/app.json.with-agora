{
  "expo": {
    "name": "Casa Nirvana User App",
    "slug": "casa-nirvana-user",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic", 
    "splash": {
      "image": "./assets/images/splashBg.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.casanirvana.user",
      "buildNumber": "1.0.0",
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "package": "com.casanirvana.user",
        "versionCode": 1,
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.casanirvana.user"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      "expo-camera",
      "expo-secure-store",
      [
        "react-native-agora",
        {
          "microphone": "Allow this app to access your microphone for voice calls",
          "camera": "Allow this app to access your camera for video calls"
        }
      ]
    ],
    "extra": {
      "EXPO_PUBLIC_SUPABASE_URL": "",
      "EXPO_PUBLIC_SUPABASE_ANON_KEY": "",
      "API_BASE_URL": "http://localhost:8080",
      "router": {
        "origin": false
      }
    }
  }
}
